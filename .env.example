# Emby Episode Organizer 运行配置示例
# 复制为 .env 并按需修改

# 数据库连接串（默认 SQLite，相对容器内 /app/backend 路径）
DATABASE_URL=sqlite+aiosqlite:///./data/app.db

# 操作日志输出目录
LOG_DIR=./data/logs

# 允许浏览/操作的根目录白名单（逗号分隔，路径安全边界）
# 必须与 docker-compose.yml 里挂载的容器内路径对应
ALLOWED_BROWSE_ROOTS=/downloads,/staging,/media

# Emby 服务器默认地址（前端预填）
EMBY_DEFAULT_URL=http://localhost:8096
